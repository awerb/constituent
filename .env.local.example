# Local development environment overrides
# Copy this file to .env.local and update values for local development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/constituent_response?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# NextAuth
NEXTAUTH_SECRET=dev-secret-key-only-for-local-development-change-in-production
NEXTAUTH_URL=http://localhost:3000

# AI Provider (choose one)
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-dev-key
ANTHROPIC_API_KEY=sk-ant-your-dev-key

# Email (optional for local development)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@localhost

# Townhall/Constituent API (optional)
TC_API_KEY=dev-api-key
TC_WEBHOOK_SECRET=dev-webhook-secret

# Application
APP_URL=http://localhost:3000
LOG_LEVEL=debug
