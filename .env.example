# ========== Deployment Configuration ==========
# Mode of operation: 'single-tenant' for single customer, 'multi-tenant' for multiple customers
DEPLOYMENT_MODE=single-tenant

# ========== Database Configuration ==========
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database?schema=public
DATABASE_URL=postgresql://user:password@localhost:5432/constituent_response?schema=public

# ========== Redis Configuration ==========
# Redis connection URL for BullMQ job queue and caching
# Format: redis://[:password@]host:port[/db]
REDIS_URL=redis://localhost:6379

# ========== NextAuth Configuration ==========
# Secret for NextAuth session encryption - generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-generate-with-openssl
# The URL where your application is deployed
NEXTAUTH_URL=http://localhost:3000

# ========== AI Provider Configuration ==========
# Choose your AI provider: 'openai' or 'anthropic'
AI_PROVIDER=openai
# OpenAI API key for GPT models
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here
# Anthropic API key for Claude models
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ========== Email Configuration ==========
# SMTP server configuration for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
# Email address to use as sender
SMTP_FROM=noreply@constituent-response.com

# ========== Third-party Services ==========
# Townhall/Constituent API configuration
TC_API_KEY=your-townhall-api-key
TC_WEBHOOK_SECRET=your-webhook-secret

# ========== Application Configuration ==========
# Base URL of the application
APP_URL=http://localhost:3000
# Log level: 'debug' | 'info' | 'warn' | 'error'
LOG_LEVEL=info

# ========== Simple Mode (for small cities) ==========
# Set to 'true' to enable simplified interface for small teams (< 5 staff)
# Hides advanced features, simplifies navigation, reduces complexity
# Can be changed later without data loss
SIMPLE_MODE=false

# ========== Cost Controls ==========
# Maximum AI drafts per month (0 = unlimited, set to control costs)
# At ~$0.01/draft: 100 drafts = ~$1/month, 1000 = ~$10/month
# Example: AI_MONTHLY_DRAFT_LIMIT=100 would limit to 100 drafts/month
AI_MONTHLY_DRAFT_LIMIT=0

# ========== Import ==========
# Maximum CSV import size in MB (prevents very large imports)
# Default: 50MB, suitable for migrations from spreadsheets
# Increase if importing very large datasets
CSV_IMPORT_MAX_SIZE_MB=50
